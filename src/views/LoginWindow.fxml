<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>


<AnchorPane id="AnchorPane" prefHeight="233.0" prefWidth="334.0" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/24.0.1" fx:controller="controller.LoginWindowController">
   <children>
      <Label layoutX="25.0" layoutY="22.0" prefHeight="34.0" prefWidth="291.0" text="Bienvenido a Apnabi Agenda Visual" textAlignment="CENTER" wrapText="true">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="33.0" layoutY="76.0" prefHeight="26.0" prefWidth="74.0" text="Nombre:" />
      <TextField fx:id="nameField" layoutX="120.0" layoutY="76.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu nombre" />
      <Label layoutX="33.0" layoutY="118.0" prefHeight="26.0" prefWidth="74.0" text="Contraseña:" />
      <PasswordField fx:id="passField" layoutX="120.0" layoutY="118.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" />
      <TextField fx:id="passFieldVisible" layoutX="120.0" layoutY="118.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" visible="false" />
      <CheckBox fx:id="cbShowPass" layoutX="139.0" layoutY="151.0" mnemonicParsing="false" onAction="#showPass" prefHeight="26.0" prefWidth="138.0" text="Mostrar contraseña" />
      <Button fx:id="btnLogin" layoutX="111.0" layoutY="184.0" mnemonicParsing="false" onAction="#login" prefHeight="34.0" prefWidth="119.0" text="Login" />
   </children>
</AnchorPane>
