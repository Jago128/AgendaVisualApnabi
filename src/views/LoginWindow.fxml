<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="243.0" prefWidth="348.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginWindowController">
   <children>
      <Label layoutX="25.0" layoutY="14.0" prefHeight="34.0" prefWidth="291.0" text="Bienvenido a Apnabi Agenda Visual!" textAlignment="CENTER" wrapText="true">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="50.0" layoutY="60.0" prefHeight="26.0" prefWidth="54.0" text="Nombre:" />
      <TextField fx:id="nameField" layoutX="120.0" layoutY="60.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu nombre" />
      <Label layoutX="43.0" layoutY="102.0" prefHeight="26.0" prefWidth="68.0" text="Contraseña:" />
      <PasswordField fx:id="passField" layoutX="120.0" layoutY="102.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" />
      <TextField fx:id="passFieldVisible" layoutX="120.0" layoutY="118.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" visible="false" />
      <CheckBox fx:id="cbShowPass" layoutX="105.0" layoutY="135.0" mnemonicParsing="false" onAction="#showPass" prefHeight="26.0" prefWidth="138.0" text="Mostrar contraseña" />
      <Button fx:id="btnLogin" layoutX="111.0" layoutY="168.0" mnemonicParsing="false" onAction="#login" prefHeight="34.0" prefWidth="119.0" text="Iniciar sesion" />
      <Label layoutX="77.0" layoutY="208.0" prefHeight="26.0" prefWidth="106.0" text="¿No tienes cuenta?" />
      <Button fx:id="btnSignUp" layoutX="186.0" layoutY="205.0" mnemonicParsing="false" onAction="#signUpWindow" prefHeight="31.0" prefWidth="87.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-underline: true;" text="Registrate" textFill="#007bff">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
         <font>
            <Font size="14.0" />
         </font>
      </Button>
   </children>
</AnchorPane>
