<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="449.0" prefWidth="254.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.SignUpWindowController">
   <children>
      <Label layoutX="22.0" layoutY="14.0" prefHeight="26.0" prefWidth="79.0" text="Registrar">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="14.0" layoutY="60.0" prefHeight="22.0" prefWidth="62.0" text="Nombre:">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <TextField fx:id="textFieldName" layoutX="84.0" layoutY="58.0" />
      <Label layoutX="13.0" layoutY="98.0" prefHeight="22.0" prefWidth="69.0" text="Apellidos:">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <TextField fx:id="textFieldSurname" layoutX="84.0" layoutY="96.0" />
      <Label layoutX="25.0" layoutY="134.0" prefHeight="22.0" prefWidth="42.0" text="Email:">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <TextField fx:id="textFieldEmail" layoutX="84.0" layoutY="132.0" />
      <Label layoutX="20.0" layoutY="166.0" prefHeight="26.0" prefWidth="55.0" text="Genero:">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <ComboBox fx:id="comboBoxGender" layoutX="84.0" layoutY="166.0" prefHeight="26.0" prefWidth="150.0" />
      <Label layoutX="76.0" layoutY="204.0" prefHeight="22.0" prefWidth="102.0" text="Nueva contraseña:" />
      <PasswordField fx:id="passField" layoutX="36.0" layoutY="228.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" />
      <TextField fx:id="passFieldVisible" layoutX="36.0" layoutY="228.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" visible="false" />
      <Label layoutX="62.0" layoutY="262.0" prefHeight="22.0" prefWidth="139.0" text="Repita nueva contraseña:" />
      <PasswordField fx:id="passFieldRepeat" layoutX="36.0" layoutY="284.0" prefHeight="26.0" prefWidth="187.0" promptText="Repite tu contraseña" />
      <TextField fx:id="passFieldRepeatVisible" layoutX="36.0" layoutY="284.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="26.0" prefWidth="187.0" promptText="Repite tu contraseña" visible="false" />
      <CheckBox fx:id="cbShowPass" layoutX="62.0" layoutY="321.0" mnemonicParsing="false" onAction="#showPass" prefHeight="26.0" prefWidth="138.0" text="Mostrar contraseña" />
      <Button fx:id="btnSignUp" layoutX="66.0" layoutY="359.0" mnemonicParsing="false" onAction="#signUp" prefHeight="34.0" prefWidth="119.0" text="Registrar" />
      <Label layoutX="24.0" layoutY="399.0" prefHeight="26.0" prefWidth="102.0" text="¿Tienes cuenta ya?" />
      <Button fx:id="btnLogin" layoutX="132.0" layoutY="396.0" mnemonicParsing="false" onAction="#loginWindow" prefHeight="31.0" prefWidth="102.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-underline: true;" text="Iniciar sesion" textFill="#007bff">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Button fx:id="btnExit" layoutX="161.0" layoutY="14.0" mnemonicParsing="false" onAction="#exit" prefHeight="27.0" prefWidth="78.0" text="Salir" />
   </children>
</AnchorPane>
