<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="406.0" prefWidth="290.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ModifyWindowController">
   <children>
      <Label layoutX="24.0" layoutY="14.0" prefHeight="27.0" prefWidth="130.0" text="Modificar rutina">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextArea fx:id="textAreaInstruction" layoutX="16.0" layoutY="150.0" prefHeight="200.0" prefWidth="257.0" wrapText="true" />
      <Label layoutX="16.0" layoutY="123.0" prefHeight="26.0" prefWidth="184.0" text="Instruccion (max 500 caracteres):" />
      <Button fx:id="btnModify" layoutX="82.0" layoutY="357.0" mnemonicParsing="false" onAction="#modify" prefHeight="41.0" prefWidth="130.0" text="Modificar rutina" />
      <Label layoutX="82.0" layoutY="55.0" prefHeight="26.0" prefWidth="41.0" text="Titulo:" />
      <TextField fx:id="textFieldTitle" layoutX="127.0" layoutY="54.0" />
      <Label layoutX="24.0" layoutY="86.0" prefHeight="26.0" prefWidth="97.0" text="Nombre persona:" />
      <TextField fx:id="textFieldPerson" layoutX="127.0" layoutY="87.0" />
      <Button fx:id="btnExit" layoutX="202.0" layoutY="14.0" mnemonicParsing="false" onAction="#exit" prefHeight="27.0" prefWidth="78.0" text="Salir" />
   </children>
</AnchorPane>
