<AnchorPane id="AnchorPane" prefHeight="513.0" prefWidth="542.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ModifyWindowController">
   <children>
      <Label alignment="CENTER" layoutX="169.0" layoutY="14.0" prefHeight="27.0" prefWidth="184.0" text="Modificar rutina">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label alignment="CENTER_RIGHT" layoutX="173.0" layoutY="56.0" prefHeight="26.0" prefWidth="41.0" text="Titulo:" />
      <TextField fx:id="textFieldTitle" layoutX="231.0" layoutY="51.0" />
      <TextArea fx:id="textAreaInstruction" layoutX="15.0" layoutY="212.0" prefHeight="223.0" prefWidth="514.0" wrapText="true" />
      <Label layoutX="18.0" layoutY="182.0" prefHeight="26.0" prefWidth="219.0" text="Instruccion (max 500 caracteres):" />
      <Button fx:id="btnModify" layoutX="182.0" layoutY="444.0" mnemonicParsing="false" onAction="#modify" prefHeight="53.0" prefWidth="158.0" text="Modificar rutina" />
      <Label alignment="CENTER_RIGHT" layoutX="102.0" layoutY="83.0" prefHeight="26.0" prefWidth="114.0" text="Nombre persona:" />
      <TextField fx:id="textFieldPerson" layoutX="231.0" layoutY="83.0" />
