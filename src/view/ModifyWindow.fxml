      <Button fx:id="imageSelector" layoutX="136.0" layoutY="142.0" mnemonicParsing="false" onAction="#selectImages" prefHeight="35.0" prefWidth="150.0" text="Seleccionar imagenes" />
      <Label fx:id="labelFiles" layoutX="12.0" layoutY="112.0" prefHeight="27.0" prefWidth="514.0" text="Imagenes seleccionadas:" />
      <Hyperlink fx:id="link" alignment="CENTER" layoutX="298.0" layoutY="148.0" onAction="#openBrowser" prefHeight="27.0" prefWidth="106.0" text="ARASAAC" />
   </children>
</AnchorPane>
