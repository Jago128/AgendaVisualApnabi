      <TextField fx:id="textFieldTitle" layoutX="215.0" layoutY="55.0" />
      <TextArea fx:id="textAreaInstruction" layoutX="14.0" layoutY="149.0" prefHeight="260.0" prefWidth="492.0" wrapText="true" />
