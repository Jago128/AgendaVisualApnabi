<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="211.0" prefWidth="401.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DeleteUserWindowController">
   <children>
      <Label layoutX="121.0" layoutY="7.0" prefHeight="38.0" prefWidth="124.0" text="Borrar cuenta">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="99.0" layoutY="45.0" prefHeight="30.0" prefWidth="62.0" text="Nombre:" />
      <Label fx:id="labelUsername" layoutX="174.0" layoutY="48.0" prefHeight="26.0" prefWidth="62.0" text="Username" />
      <Label layoutX="80.0" layoutY="80.0" prefHeight="26.0" prefWidth="87.0" text="Contraseña:" />
      <PasswordField fx:id="passField" layoutX="172.0" layoutY="79.0" prefHeight="26.0" prefWidth="172.0" promptText="Introduce tu contraseña" />
      <TextField fx:id="passFieldVisible" layoutX="172.0" layoutY="79.0" nodeOrientation="LEFT_TO_RIGHT" prefHeight="26.0" prefWidth="172.0" promptText="Introduce tu contraseña" visible="false" />
      <CheckBox fx:id="cbShowPass" layoutX="123.0" layoutY="114.0" mnemonicParsing="false" onAction="#showPass" prefHeight="26.0" prefWidth="163.0" text="Mostrar contraseña" />
      <Button fx:id="delete" layoutX="143.0" layoutY="151.0" mnemonicParsing="false" onAction="#delete" prefHeight="44.0" prefWidth="114.0" text="Borrar cuenta" textFill="RED" />
      <Button fx:id="btnExit" layoutX="299.0" layoutY="11.0" mnemonicParsing="false" onAction="#exit" prefHeight="30.0" prefWidth="87.0" text="Salir" />
   </children>
</AnchorPane>
