<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="290.0" prefWidth="406.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginWindowController">
   <children>
      <Label layoutX="22.0" layoutY="24.0" prefHeight="34.0" prefWidth="266.0" text="Bienvenido a Apnabi Agenda Virtual!" textAlignment="CENTER" wrapText="true">
         <font>  
            <Font size="15.0" />
         </font>
      </Label>
      <Label layoutX="74.0" layoutY="86.0" prefHeight="26.0" prefWidth="68.0" text="Nombre:" />
      <TextField fx:id="textfieldName" layoutX="147.0" layoutY="86.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu nombre" />
      <Label layoutX="64.0" layoutY="122.0" prefHeight="26.0" prefWidth="80.0" text="Contraseña:" />
      <PasswordField fx:id="passwordField" layoutX="147.0" layoutY="122.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" />
      <TextField fx:id="passwordFieldVisible" layoutX="147.0" layoutY="122.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" visible="false" />
      <CheckBox fx:id="cbShowPass" layoutX="126.0" layoutY="155.0" mnemonicParsing="false" onAction="#showPass" prefHeight="34.0" prefWidth="171.0" text="Mostrar contraseña">
         <font>
            <Font size="14.0" />
         </font></CheckBox>
      <Button fx:id="btnLogin" layoutX="143.0" layoutY="197.0" mnemonicParsing="false" onAction="#login" prefHeight="34.0" prefWidth="119.0" text="Iniciar sesion" />
      <Label layoutX="77.0" layoutY="240.0" prefHeight="42.0" prefWidth="138.0" text="¿No tienes cuenta?">
         <font>
            <Font size="14.0" />
         </font></Label>
      <Button fx:id="btnSignUp" layoutX="217.0" layoutY="244.0" mnemonicParsing="false" onAction="#signUpWindow" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-underline: true;" text="Registrate" textFill="#007bff">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Button fx:id="btnExit" layoutX="299.0" layoutY="24.0" mnemonicParsing="false" onAction="#exit" prefHeight="34.0" prefWidth="80.0" text="Salir" />
   </children>
</AnchorPane>
