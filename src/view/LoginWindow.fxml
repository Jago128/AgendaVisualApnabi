<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="260.0" prefWidth="295.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.LoginWindowController">
   <children>
      <Label layoutX="65.0" layoutY="16.0" prefHeight="34.0" prefWidth="98.0" text="Bienvenido!" textAlignment="CENTER" wrapText="true">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <Label layoutX="33.0" layoutY="60.0" prefHeight="26.0" prefWidth="54.0" text="Nombre:" />
      <TextField fx:id="textfieldName" layoutX="103.0" layoutY="60.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu nombre" />
      <Label layoutX="26.0" layoutY="102.0" prefHeight="26.0" prefWidth="68.0" text="Contraseña:" />
      <PasswordField fx:id="passwordField" layoutX="103.0" layoutY="102.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" />
      <TextField fx:id="passwordFieldVisible" layoutX="120.0" layoutY="102.0" prefHeight="26.0" prefWidth="187.0" promptText="Introduce tu contraseña" visible="false" />
      <CheckBox fx:id="cbShowPass" layoutX="97.0" layoutY="137.0" mnemonicParsing="false" onAction="#showPass" prefHeight="26.0" prefWidth="138.0" text="Mostrar contraseña" />
      <Button fx:id="btnLogin" layoutX="94.0" layoutY="170.0" mnemonicParsing="false" onAction="#login" prefHeight="34.0" prefWidth="119.0" text="Iniciar sesion" />
      <Label layoutX="55.0" layoutY="217.0" prefHeight="26.0" prefWidth="106.0" text="¿No tienes cuenta?" />
      <Button fx:id="btnSignUp" layoutX="161.0" layoutY="211.0" mnemonicParsing="false" onAction="#signUpWindow" prefHeight="34.0" prefWidth="90.0" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-underline: true;" text="Registrate" textFill="#007bff">
         <cursor>
            <Cursor fx:constant="HAND" />
         </cursor>
         <font>
            <Font size="14.0" />
         </font>
      </Button>
      <Button fx:id="btnExit" layoutX="214.0" layoutY="20.0" mnemonicParsing="false" onAction="#exit" prefHeight="27.0" prefWidth="78.0" text="Salir" />
   </children>
</AnchorPane>
